# Optional environment variables for MCP client config.
# The server does not automatically load this file; copy these values into your MCP client env.

# Public URL of the shared Canvas PRD web app.
PRD_CANVAS_BASE_URL=http://127.0.0.1:5180

# Set this to enable shared central API mode.
# In central API mode, MCP writes into the Canvas PRD web service instead of this kit's local SQLite.
PRD_CANVAS_API_TOKEN=

# Required in central API mode. Must be an account already created in the Canvas PRD web app.
PRD_CANVAS_MCP_OWNER_USERNAME=

# Local/offline fallback only. Ignored when PRD_CANVAS_API_TOKEN is set.
DATABASE_PATH=data/prd-canvas.sqlite

# Local/offline fallback only. Ignored when PRD_CANVAS_API_TOKEN is set.
STORAGE_ROOT=storage
