# Optional environment variables for MCP client config.
# The server does not automatically load this file; copy these values into your MCP client env.

# Public URL of the PRD Canvas web app, used only in tool responses.
PRD_CANVAS_BASE_URL=http://127.0.0.1:5180

# Optional owner username. If empty, the server uses an existing local user when possible,
# otherwise it creates/uses "mcp-agent".
PRD_CANVAS_MCP_OWNER_USERNAME=

# SQLite database path. Relative paths are resolved from the kit root by MCP configs generated by scripts/install.mjs.
DATABASE_PATH=data/prd-canvas.sqlite

# File storage path for uploaded HTML/images and exported Markdown.
STORAGE_ROOT=storage
